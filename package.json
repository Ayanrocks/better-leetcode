{
  "name": "better-leetcode",
  "displayName": "Better Leetcode",
  "description": "A flexible and robust VS Code extension for solving Leetcode problems.",
  "version": "0.0.1",
  "publisher": "better-leetcode-team",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "better-leetcode-explorer",
          "title": "Better LeetCode",
          "icon": "resources/leetcode.svg"
        }
      ],
      "panel": [
        {
          "id": "better-leetcode-results",
          "title": "Test Results",
          "icon": "resources/leetcode.svg"
        }
      ]
    },
    "views": {
      "better-leetcode-explorer": [
        {
          "id": "better-leetcode.views.dailyChallenge",
          "name": "Daily Challenge"
        },
        {
          "id": "better-leetcode.views.allProblems",
          "name": "Problems"
        },
        {
          "id": "better-leetcode.views.studyLists",
          "name": "Study Lists"
        }
      ],
      "better-leetcode-results": [
        {
          "id": "better-leetcode.views.testResults",
          "name": "Test Results",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "better-leetcode.signin",
        "title": "Better LeetCode: Sign In",
        "icon": "$(sign-in)"
      },
      {
        "command": "better-leetcode.signout",
        "title": "Better LeetCode: Sign Out"
      },
      {
        "command": "better-leetcode.showUser",
        "title": "Better LeetCode: Show Logged-in User"
      },
      {
        "command": "better-leetcode.openProblem",
        "title": "Better LeetCode: Open Problem"
      },
      {
        "command": "better-leetcode.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "better-leetcode.search",
        "title": "Search Problem",
        "icon": "$(search)"
      },
      {
        "command": "better-leetcode.testSolution",
        "title": "Test",
        "icon": "$(play)"
      },
      {
        "command": "better-leetcode.submitSolution",
        "title": "Submit",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "better-leetcode.changeLanguage",
        "title": "Change Language",
        "icon": "$(code)"
      },
      {
        "command": "better-leetcode.showProblemStatement",
        "title": "Show Problem Statement",
        "icon": "$(book)"
      },
      {
        "command": "better-leetcode.openEditor",
        "title": "Open Editor",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "better-leetcode.showProblemStatement",
          "group": "navigation@0",
          "when": "editorTextFocus && better-leetcode.isLeetCodeEditor"
        },
        {
          "command": "better-leetcode.changeLanguage",
          "group": "navigation@1",
          "when": "editorTextFocus && better-leetcode.isLeetCodeEditor"
        },
        {
          "command": "better-leetcode.testSolution",
          "group": "navigation@2",
          "when": "editorTextFocus && better-leetcode.isLeetCodeEditor"
        },
        {
          "command": "better-leetcode.submitSolution",
          "group": "navigation@3",
          "when": "editorTextFocus && better-leetcode.isLeetCodeEditor"
        },
        {
          "command": "better-leetcode.openEditor",
          "group": "navigation@0",
          "when": "activeWebviewPanelId == 'problemWebview'"
        }
      ],
      "view/title": [
        {
          "command": "better-leetcode.refresh",
          "when": "view == better-leetcode.views.dailyChallenge || view == better-leetcode.views.allProblems || view == better-leetcode.views.studyLists",
          "group": "navigation@1"
        },
        {
          "command": "better-leetcode.search",
          "when": "view == better-leetcode.views.allProblems",
          "group": "navigation@2"
        },
        {
          "command": "better-leetcode.signin",
          "when": "view == better-leetcode.views.dailyChallenge && !better-leetcode.isSignedIn",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Better Leetcode",
      "properties": {
        "better-leetcode.endpoint": {
          "type": "string",
          "default": "https://leetcode.com",
          "enum": [
            "https://leetcode.com",
            "https://leetcode.cn"
          ],
          "enumDescriptions": [
            "LeetCode Global (leetcode.com)",
            "LeetCode China (leetcode.cn)"
          ],
          "description": "The LeetCode endpoint to use."
        },
        "better-leetcode.storagePath": {
          "type": "string",
          "default": "",
          "description": "The local directory where LeetCode problem solutions will be stored."
        },
        "better-leetcode.defaultLanguage": {
          "type": "string",
          "default": "",
          "enum": [
            "cpp",
            "java",
            "python3",
            "python",
            "javascript",
            "typescript",
            "csharp",
            "c",
            "golang",
            "kotlin",
            "swift",
            "rust",
            "ruby",
            "php"
          ],
          "description": "The default language to generate code files in."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "package": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "compile-tests": "tsc -p tsconfig.test.json",
    "watch-tests": "tsc -p tsconfig.test.json -w",
    "pretest": "npm run compile && npm run compile-tests",
    "test": "node ./out/test/runTest.js",
    "lint": "eslint src --ext ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.7.1",
    "@typescript-eslint/parser": "^7.7.1",
    "@vscode/test-electron": "^2.3.9",
    "esbuild": "^0.20.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "mocha": "^10.4.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  }
}
